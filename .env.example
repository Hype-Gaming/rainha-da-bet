PORT=3098
NODE_ENV=production

# Login do painel admin (/admin) — auth PRÓPRIA, sem Cactus.
# E-mails autorizados, separados por vírgula. Ex: ADMIN_EMAILS=admin@exemplo.com,socio@exemplo.com
ADMIN_EMAILS=admin@exemplo.com,socio@exemplo.com

# Senha de login do admin (usada com qualquer e-mail da allowlist acima).
# Se ADMIN_EMAILS ou ADMIN_PASSWORD estiverem vazios, o login fica desativado.
ADMIN_PASSWORD=troque-esta-senha

# (Opcional) Segredo para assinar a sessão do admin. Se ausente, usa ADMIN_PASSWORD.
# ADMIN_SESSION_SECRET=uma-string-longa-e-aleatoria

# Token do webhook da Lastlink (usado em /api/webhook/lastlink?token=...).
# Obrigatório: sem ele o webhook rejeita todas as chamadas (401).
LASTLINK_WEBHOOK_SECRET=coloque-um-token-secreto-aqui

# Conexao Mongo (se ausente, usa o fallback do codigo).
# MONGODB_URI=mongodb://usuario:senha@host:27017/rainha_da_bet?authSource=rainha_da_bet
# Nome do banco. Se ausente, usa 'rainha_da_bet'. O codigo usa client.db(MONGO_DB_NAME),
# que tem prioridade sobre o nome de banco que estiver na URI acima.
# MONGO_DB_NAME=rainha_da_bet

# Origem do catalogador (proxy /api/catalogador). Se ausente, usa o fallback do codigo.
# CATALOGADOR_ORIGIN=https://casino-data.grupoautoma.com
